# 1 Page — Environment Variables

# Admin password for /admin dashboard
NEXT_PUBLIC_ADMIN_PASSWORD=admin

# Cloudflare Turnstile (bot protection)
NEXT_PUBLIC_TURNSTILE_SITEKEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Umami Analytics (optional)
NEXT_PUBLIC_UMAMI_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# GitHub API (for admin publishing — optional for local dev)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main

# Donation links (optional — enables footer + /donate page)
NEXT_PUBLIC_GITHUB_SPONSORS_URL=
NEXT_PUBLIC_STRIPE_DONATION_URL=

# AI Workflow Generator (optional — enables /generate page)
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1
