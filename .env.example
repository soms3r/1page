# 1 Page — Environment Variables

# Admin password — REQUIRED. Build fails if unset.
# The SHA-256 hash (not plaintext) is embedded in the bundle at build time.
# Copy this file to .env.local and change the password before deploying.
ADMIN_PASSWORD=admin

# GitHub API config for admin publishing (required for GitHub commit in admin panel)
NEXT_PUBLIC_GITHUB_OWNER=your-org-or-username
NEXT_PUBLIC_GITHUB_REPO=1page
NEXT_PUBLIC_GITHUB_BRANCH=main

# Cloudflare Turnstile (bot protection — optional)
NEXT_PUBLIC_TURNSTILE_SITEKEY=
TURNSTILE_SECRET_KEY=

# Umami Analytics (optional)
NEXT_PUBLIC_UMAMI_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# AI Workflow Generator (optional — enables /generate page)
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1
