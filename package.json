{
  "name": "1page-opensource",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "npx tsx src/scripts/build-admin-hash.ts && npm run build-index && npx tsx src/scripts/build-starter-packs.ts && npx tsx src/scripts/build-sitemap.ts && next build --webpack && npx tsx src/scripts/post-build.ts",
    "start": "npx serve out",
    "lint": "eslint",
    "build-starter-packs": "npx tsx src/scripts/build-starter-packs.ts",
    "build-settings": "npx tsx src/scripts/build-settings.ts",
    "build-index": "npm run build-settings && npx tsx src/scripts/build-index.ts && npm run build-search-index && npm run build-content && npm run seo-enrich",
    "seo-enrich": "npx tsx src/scripts/seo-enrich.ts",
    "build-content": "npx tsx src/scripts/build-content-expansion.ts",
    "build-search-index": "npx tsx src/scripts/build-search-index.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "fuse.js": "^7.3.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.17.30",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "serve": "^14.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
